# HTML and text files - always fetch fresh
/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JavaScript - versioned via ?v=N query string, safe to cache
/*.js
  Cache-Control: no-cache, no-store, must-revalidate

# Text files (DawnPrompt.txt) - always fetch fresh
/*.txt
  Cache-Control: no-cache, no-store, must-revalidate

# Images - immutable, cache aggressively (filename never changes)
/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.gif
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable
